# ═══════════════════════════════════════════════════════════════════════
#  zenodo-drop environment variables
#  Copy this file to .env and fill in your values.
#  Or export these in your shell profile (~/.bashrc, ~/.zshrc, etc.)
# ═══════════════════════════════════════════════════════════════════════

# Zenodo API tokens — get yours at:
#   Live:    https://zenodo.org/account/settings/applications/
#   Sandbox: https://sandbox.zenodo.org/account/settings/applications/
# Both tokens need scopes: deposit:write, deposit:actions
ZENODO_TOKEN=your-live-token-here
ZENODO_SANDBOX_TOKEN=your-sandbox-token-here

# Default author info (used when auto-extracting metadata from PDFs)
# Format: "Last, First"
ZENODO_AUTHOR_NAME=Last, First
ZENODO_AUTHOR_AFFILIATION=Your Institution
ZENODO_AUTHOR_ORCID=
